#!/usr/bin/env bash
# cdecl — explain C declarations in English
#
# WHAT IT DOES
#   Translates C declaration syntax into plain English. Handles pointers,
#   arrays, function pointers, and arbitrarily nested declarators. Reads
#   from a single argument or stdin, one declaration per line.
#
#   Lines that cannot be parsed (comments, blanks, errors) output blank lines
#   to preserve line correspondence with input.
#
# WHY
#   C declaration syntax is inside-out: the name sits in the middle and
#   types wrap around it in parsing order, not reading order. cdecl unwinds
#   the grammar and renders it left-to-right in English.
#
# HOW IT WORKS
#   Tokenizes the declaration, then applies recursive-descent parsing:
#   parse_specifiers reads the base type; parse_declarator handles prefix
#   operators (pointers, cv-qualifiers, grouped sub-declarators);
#   parse_postfix handles suffix operators (arrays, function parameters) —
#   in postfix position a '(' is always a parameter list, never a sub-declarator.
#   parse_params recurses to handle function pointer parameters.
#
# USAGE
#   cdecl DECLARATION
#   cdecl -h | --help
#   cdecl < file
#
# EXAMPLES
#   cdecl 'int *p'
#   → p is pointer to int
#
#   cdecl 'int (*fp)(int, char)'
#   → fp is pointer to function (int, char) returning int
#
#   cdecl 'int (*arr)[10]'
#   → arr is pointer to array 10 of int
#
#   cdecl 'void (*signal(int, void (*)(int)))(int)'
#   → signal is function (int, pointer to function (int) returning void)
#     returning pointer to function (int) returning void
#
#   cdecl < examples/cdecl.txt

set -euo pipefail

usage() {
    cat <<'EOF'
Usage: cdecl DECLARATION
       cdecl -h | --help
       cdecl < file

Explain C declarations in English.

Examples:
  cdecl 'int *p'         → p is pointer to int
  cdecl 'int (*fp)(int)' → fp is pointer to function (int) returning int
EOF
}

has_args()        { [[ $# -gt 0 ]]; }
is_help()         { [[ $1 == -h || $1 == --help ]]; }
has_stdin_input() { [[ ! -t 0 ]]; }

readonly AWK='
# ── predicates ────────────────────────────────────────────────────────────────

function is_type_specifier(t) {
    return t ~ /^(void|char|short|int|long|float|double|signed|unsigned|const|volatile|struct|union|enum)$/
}

function is_tagged_type(t) { return t == "struct" || t == "union" || t == "enum" }
function is_qualifier(t)   { return t ~ /^(const|volatile)$/ }
function is_identifier(t)  { return t ~ /^[a-zA-Z_][a-zA-Z0-9_]*$/ }
function is_pointer(t)     { return t == "*" }
function is_empty(n)       { return n == 0 }
function is_skip(line)     { return line ~ /^[[:space:]]*(#|$)/ }

# ── tokenizer ─────────────────────────────────────────────────────────────────

function tokenize(s,    n) {
    gsub(/[[:space:]]+/, " ", s)
    gsub(/\(/, " ( ", s)
    gsub(/\)/, " ) ", s)
    gsub(/\[/, " [ ", s)
    gsub(/\]/, " ] ", s)
    gsub(/\*/, " * ", s)
    gsub(/,/,  " , ", s)
    gsub(/;/,  " ; ", s)
    gsub(/[[:space:]]+/, " ", s)
    gsub(/^[[:space:]]+|[[:space:]]+$/, "", s)

    n = split(s, tokens, " ")
    return n
}

# ── parser ────────────────────────────────────────────────────────────────────

function parse_specifiers(    spec, t) {
    spec = ""
    while (pos <= ntokens && is_type_specifier(tokens[pos])) {
        t = tokens[pos++]
        spec = spec t " "
        if (is_tagged_type(t)) { spec = spec tokens[pos++] " " }
    }
    gsub(/[[:space:]]+$/, "", spec)
    return spec
}

function parse_declarator(    result, ptrs, quals, t) {
    ptrs = ""
    while (pos <= ntokens && is_pointer(tokens[pos])) {
        pos++
        quals = ""
        while (is_qualifier(tokens[pos])) { quals = quals tokens[pos++] " " }
        ptrs = quals "pointer to " ptrs
    }

    t = tokens[pos]
    if (t == "(")              { pos++; result = parse_declarator(); pos++ }
    else if (is_identifier(t)) { result = t " is "; pos++ }
    else                       { result = "" }

    return result parse_postfix() ptrs
}

function parse_postfix(    result, t, size, params) {
    result = ""
    while (pos <= ntokens) {
        t = tokens[pos]
        if (t == "[") {
            pos++
            if (tokens[pos] == "]") { result = result "array of "; pos++ }
            else { size = tokens[pos]; pos += 2; result = result "array " size " of " }
        } else if (t == "(") {
            pos++; params = parse_params(); pos++
            result = result "function (" params ") returning "
        } else break
    }
    return result
}

function parse_params(    result, pbase, pdecl) {
    result = ""
    while (pos <= ntokens && tokens[pos] != ")") {
        if (tokens[pos] == ",")   { pos++; result = result ", "; continue }
        if (tokens[pos] == "...") { pos++; result = result "..."; continue }
        pbase = parse_specifiers()
        pdecl = parse_declarator()
        sub(/^[a-zA-Z_][a-zA-Z0-9_]* is /, "", pdecl)
        result = result pdecl pbase
    }
    return (result == "") ? "void" : result
}

# ── main ──────────────────────────────────────────────────────────────────────

function no_base(b)   { return b == "" }
function no_result(r) { return r == "" }

function process(line,    base, result) {
    if (is_skip(line)) { print ""; return }

    ntokens = tokenize(line)
    if (is_empty(ntokens)) { print ""; return }

    pos = 1
    base = parse_specifiers()
    if (no_base(base)) { print ""; return }

    result = parse_declarator()
    if (no_result(result)) { print ""; return }

    print result base
}

{ process($0) }
'

main() {
    if has_args "$@" && is_help "$1"; then usage; exit 0; fi
    if has_args "$@"; then
        echo "$*" | awk "$AWK"
        return 0
    fi
    has_stdin_input || { usage >&2; exit 1; }
    awk "$AWK"
}

main "$@"
