#!/usr/bin/env bash
# clint — C syntax checker and linter
#
# WHAT IT DOES
# Runs gcc in syntax-only mode with strict warnings. No object files
# produced, just diagnostics. Handles ccraft-style shebangs by replacing
# them with #line directives.
#
# USAGE
#   clint [GCC_OPTIONS] FILE...
#
# EXAMPLES
#   clint foo.c
#   clint -Wpedantic *.c
#
# DEPENDENCIES
#   gcc

OPTS=()
FILES=()

for ARG in "$@"; do
    [[ $ARG == -* ]] && OPTS+=("$ARG") || FILES+=("$ARG")
done

for FILE in "${FILES[@]}"; do
    sed "1 { s|^#!.*|#line 2 \"${FILE}\"|; t; s|^|#line 1 \"${FILE}\"\n| }" "$FILE" \
    | gcc -fsyntax-only -Wall -Wextra "${OPTS[@]}" -x c -
done
