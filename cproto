#!/usr/bin/env bash
# cproto — extract C function prototypes and type definitions
#
# WHAT IT DOES
# Parses C source using clang's AST to extract function declarations and
# optionally type definitions (struct/enum/typedef). Outputs valid C that
# can be used as a header file.
#
# HOW IT WORKS
# 1. Replace shebang with spaces to preserve byte offsets
# 2. Run clang -ast-dump=json to get full AST (once, reused for all extractions)
# 3. Filter FunctionDecl nodes, extract return type + params, format as decl
# 4. If -T: extract TypedefDecl/RecordDecl/EnumDecl via byte ranges
# 5. If -f: find struct names referenced as pointers but not defined locally
# 6. If -S: topological sort types by direct (non-pointer) dependencies
# 7. If -g: wrap output in #ifndef/#define/#endif guards
# 8. Output: [guards] [forward decls] [types] [functions] [guards]
#
# USAGE
#   cproto [OPTIONS] FILE
#
# OPTIONS
#   -s        Include static functions
#   -T        Include type definitions (struct/enum/typedef)
#   -g        Wrap output in include guards
#   -f        Add forward declarations for incomplete types
#   -S        Sort types by dependency order
#   -D NAME   Define preprocessor symbol (repeatable)
#   -I DIR    Add include directory (repeatable)
#
# EXAMPLES
#   cproto foo.c                        # public functions only
#   cproto -s foo.c                     # include static functions
#   cproto -T foo.c                     # include type definitions
#   cproto -T foo.c > foo.h             # generate header
#   cproto -D IMPLEMENTATION -T stb.h   # STB-style header
#
# DEPENDENCIES
#   clang, jq

set -euo pipefail

# ============================================================================
# Configuration
# ============================================================================

SHOW_STATIC=0
SHOW_TYPES=0
SHOW_GUARDS=0
SHOW_FORWARD=0
SORT_DEPS=0
DEFINES=()
INCLUDES=()
CLEANUP_FILES=()

# ============================================================================
# Helpers
# ============================================================================

die()                { echo "cproto: $*" >&2; exit 1; }
got()                { [[ -n $1 ]]; }
has_arguments()      { [[ $# -gt 0 ]]; }
file_exists()        { [[ -f "$1" ]]; }
has_content()        { [[ -s "$1" ]]; }
has_semicolon()      { [[ "$1" == *";" ]]; }
has_range_data()     { [[ -n "$1" && -n "$2" && -n "$3" ]]; }
is_showing_static()  { [[ $SHOW_STATIC -eq 1 ]]; }
is_showing_types()   { [[ $SHOW_TYPES -eq 1 ]]; }
is_showing_guards()  { [[ $SHOW_GUARDS -eq 1 ]]; }
is_showing_forward() { [[ $SHOW_FORWARD -eq 1 ]]; }
is_sorting_deps()    { [[ $SORT_DEPS -eq 1 ]]; }

# ============================================================================
# Cleanup
# ============================================================================

cleanup() {
    local FILE

    for FILE in "${CLEANUP_FILES[@]+"${CLEANUP_FILES[@]}"}"; do
        rm -f "$FILE"
    done
}
trap cleanup EXIT

register_cleanup() { CLEANUP_FILES+=("$1"); }

create_tempfile() {
    local TMPFILE

    TMPFILE=$(mktemp)
    register_cleanup "$TMPFILE"
    echo "$TMPFILE"
}

# ============================================================================
# Usage
# ============================================================================

usage() {
    cat <<EOF
Usage: cproto [OPTIONS] FILE

Generate C function prototypes using clang AST.

Options:
  -s            Include static functions
  -T            Include type definitions (struct/enum/typedef)
  -g            Wrap output in include guards
  -f            Add forward declarations for incomplete types
  -S            Sort types by dependency order
  -D NAME       Define preprocessor symbol (repeatable)
  -I DIR        Add include directory (repeatable)
  -h            Show this help

Examples:
  cproto foo.c
  cproto -s foo.c
  cproto -T foo.c
  cproto -TgfS foo.c > foo.h
EOF
}

# ============================================================================
# AST Operations
# ============================================================================

replace_shebang_with_spaces() {
    local SRC=$1
    local DST=$2

    sed '1 { /^#!/ s|.| |g }' "$SRC" > "$DST"
}

dump_ast_json() {
    local STDERR_FILE
    STDERR_FILE=$(create_tempfile)

    clang -x c -fsyntax-only -Xclang -ast-dump=json \
        ${DEFINES[@]+"${DEFINES[@]}"} \
        ${INCLUDES[@]+"${INCLUDES[@]}"} \
        "$PARSE_FILE" 2>"$STDERR_FILE" || {
            sed "s|$PARSE_FILE|$FILE|g" "$STDERR_FILE" >&2
            die "clang failed to parse $FILE"
        }
}

# ============================================================================
# Function Extraction
# ============================================================================

extract_functions() {
    local AST_FILE=$1
    local SHOW_STATIC_JSON="false"

    if is_showing_static; then SHOW_STATIC_JSON="true"; fi

    jq -r --argjson show_static "$SHOW_STATIC_JSON" '
        def get_params:
            .inner // []
            | map(select(.kind == "ParmVarDecl") | "\(.type.qualType) \(.name // "")")
            | join(", ");
        
        def get_return_type:
            if (.type.qualType | test("^(.+) \\((.*)\\)$"))
            then (.type.qualType | capture("^(?<ret>.+) \\((?<params>.*)\\)$").ret)
            else .type.qualType
            end;
        
        def format_decl:
            (get_return_type) + " " + .name + "(" + get_params + ");";
        
        def is_function:
            .kind == "FunctionDecl";
        
        def is_from_source:
            (.loc.includedFrom | not) and (.loc.spellingLoc | not);
        
        def is_visible:
            if $show_static then true
            else ((.storageClass // "") != "static")
            end;
        
        .inner[]?
        | select(is_function)
        | select(is_from_source)
        | select(is_visible)
        | format_decl
    ' "$AST_FILE"
}

# ============================================================================
# Type Extraction
# ============================================================================

extract_defined_types() {
    local AST_FILE=$1

    jq -r '
        .inner[]?
        | select(.kind == "RecordDecl" or .kind == "EnumDecl")
        | select(.completeDefinition == true)
        | select(.name != null and .name != "")
        | (if .kind == "RecordDecl" then (if .tagUsed == "union" then "union" else "struct" end) else "enum" end) as $tag
        | "\($tag) \(.name)"
    ' "$AST_FILE" | sort -u
}

extract_referenced_types() {
    local AST_FILE=$1

    jq -r '
        def find_pointer_types:
            .. | objects | select(.kind == "PointerType") | .inner[]? | select(.kind == "RecordType") | .decl.name // empty;

        .inner[]?
        | select(.kind == "RecordDecl")
        | select(.completeDefinition == true)
        | find_pointer_types
    ' "$AST_FILE" | sort -u
}

emit_forward_declarations() {
    local AST_FILE=$1
    local DEFINED
    local REFERENCED
    local TYPE

    DEFINED=$(extract_defined_types "$AST_FILE")
    REFERENCED=$(extract_referenced_types "$AST_FILE")

    while IFS= read -r TYPE; do
        got "$TYPE" || continue
        echo "$DEFINED" | grep -q "struct $TYPE" || echo "struct $TYPE;"
    done <<< "$REFERENCED"
}

# Extract type declarations from AST with byte ranges and dependencies.
# Filters: TypedefDecl/RecordDecl/EnumDecl from target file, complete, with valid range.
# Output: name\tbegin\tend\ttokLen\tdeps (deps = direct non-pointer struct/union/enum refs)
extract_type_info() {
    local AST_FILE=$1
    local ABS_FILE
    local REL_FILE
    ABS_FILE=$(realpath "$FILE") || return 1
    REL_FILE=$FILE

    jq -r --arg absfile "$ABS_FILE" --arg relfile "$REL_FILE" --arg parsefile "$PARSE_FILE" '
        def is_type_decl:
            .kind == "TypedefDecl" or .kind == "RecordDecl" or .kind == "EnumDecl";

        def is_from_target_file:
            .loc.file == $absfile or .loc.file == $relfile or .loc.file == $parsefile or (.loc.file == null and .loc.offset != null);

        def has_name:
            .name != null and .name != "";

        def is_not_included:
            .loc.includedFrom | not;

        def is_complete:
            if .kind == "RecordDecl" or .kind == "EnumDecl"
            then .completeDefinition == true
            else true
            end;

        def has_valid_range:
            .range.begin.offset != null
            and .range.end.offset != null
            and .range.end.tokLen != null;

        def get_direct_deps:
            [.. | objects | select(.kind == "FieldDecl")
             | .type.qualType // ""
             | select(test("\\*") | not)
             | capture("(?<tag>struct|union|enum) (?<name>[a-zA-Z_][a-zA-Z0-9_]*)") | .name
            ] | unique | join(",");

        .inner[]?
        | select(is_type_decl)
        | select(is_from_target_file)
        | select(has_name)
        | select(is_not_included)
        | select(is_complete)
        | select(has_valid_range)
        | .name as $name
        | .range.begin.offset as $begin
        | .range.end.offset as $end
        | .range.end.tokLen as $toklen
        | get_direct_deps as $deps
        | "\($name)\t\($begin)\t\($end)\t\($toklen)\t\($deps)"
    ' "$AST_FILE"
}

# Topological sort (Kahn's algorithm) — emit types before their dependents.
# Falls back to original order if cycle detected.
topo_sort() {
    awk -F'\t' '
    {
        type_name[NR] = $1
        begin[NR] = $2
        end[NR] = $3
        toklen[NR] = $4
        dep_list[NR] = $5
        name_to_idx[$1] = NR
        type_count++
    }
    END {
        for (i = 1; i <= type_count; i++) {
            in_degree[i] = 0
            split(dep_list[i], deps, ",")
            for (j in deps) {
                dep = deps[j]
                if (dep != "" && name_to_idx[dep] != "") {
                    provider = name_to_idx[dep]
                    dependent = i
                    adjacency[provider, ++adj_count[provider]] = dependent
                    in_degree[dependent]++
                }
            }
        }

        head = 1; tail = 0
        for (i = 1; i <= type_count; i++)
            if (in_degree[i] == 0) queue[++tail] = i

        sorted_count = 0
        while (head <= tail) {
            current = queue[head++]
            sorted[++sorted_count] = current
            for (j = 1; j <= adj_count[current]; j++) {
                neighbor = adjacency[current, j]
                if (--in_degree[neighbor] == 0) queue[++tail] = neighbor
            }
        }

        has_cycle = (sorted_count != type_count)
        for (i = 1; i <= type_count; i++) {
            idx = has_cycle ? i : sorted[i]
            print begin[idx], end[idx], toklen[idx]
        }
    }
    '
}

extract_type_ranges() {
    local AST_FILE=$1

    if is_sorting_deps; then
        extract_type_info "$AST_FILE" | topo_sort
    else
        extract_type_info "$AST_FILE" | cut -f2,3,4 | tr '\t' ' ' | sort -n -u
    fi
}

extract_source_range() {
    local SOURCE_FILE=$1
    local BEGIN=$2
    local END=$3
    local TOKLEN=$4
    local COUNT=$((END - BEGIN + TOKLEN))

    dd if="$SOURCE_FILE" bs=1 skip="$BEGIN" count="$COUNT" status=none 2>/dev/null
}

emit_type_definition() {
    local TEXT=$1

    has_semicolon "$TEXT" || TEXT="$TEXT;"
    echo "$TEXT"
    echo ""
}

extract_types() {
    local JSON_FILE=$1
    local SOURCE_FILE=$2

    extract_type_ranges "$JSON_FILE" \
    | while IFS=' ' read -r BEGIN END TOKLEN; do
        has_range_data "$BEGIN" "$END" "$TOKLEN" || continue

        local EXTRACTED
        EXTRACTED=$(extract_source_range "$SOURCE_FILE" "$BEGIN" "$END" "$TOKLEN")

        emit_type_definition "$EXTRACTED"
    done
}

# ============================================================================
# Orchestration
# ============================================================================

guard_name() {
    local NAME

    NAME=$(basename "$FILE")
    NAME=${NAME%.*}
    NAME=${NAME^^}
    NAME=${NAME//[^A-Z0-9]/_}
    echo "${NAME}_H"
}

emit_guard_begin() {
    local GUARD

    GUARD=$(guard_name)
    echo "#ifndef $GUARD"
    echo "#define $GUARD"
    echo ""
}

emit_guard_end() {
    local GUARD

    GUARD=$(guard_name)
    echo ""
    echo "#endif /* $GUARD */"
}

extract_prototypes() {
    local TMPFILE_AST
    local TMPFILE_TYPES
    local TMPFILE_FORWARD
    local FUNCTIONS

    TMPFILE_AST=$(create_tempfile)
    dump_ast_json > "$TMPFILE_AST"

    FUNCTIONS=$(extract_functions "$TMPFILE_AST")

    is_showing_types || { echo "$FUNCTIONS"; return 0; }

    if is_showing_forward; then
        TMPFILE_FORWARD=$(create_tempfile)
        emit_forward_declarations "$TMPFILE_AST" > "$TMPFILE_FORWARD"
        if has_content "$TMPFILE_FORWARD"; then
            cat "$TMPFILE_FORWARD"
            echo ""
        fi
    fi

    TMPFILE_TYPES=$(create_tempfile)
    extract_types "$TMPFILE_AST" "$PARSE_FILE" > "$TMPFILE_TYPES"

    if has_content "$TMPFILE_TYPES"; then
        cat "$TMPFILE_TYPES"
    fi

    echo "$FUNCTIONS"
}

emit_output() {
    if is_showing_guards; then emit_guard_begin; fi

    extract_prototypes

    if is_showing_guards; then emit_guard_end; fi
}

main() {
    while getopts "sTgfSD:I:h" OPT; do
        case "$OPT" in
            s) SHOW_STATIC=1 ;;
            T) SHOW_TYPES=1 ;;
            g) SHOW_GUARDS=1 ;;
            f) SHOW_FORWARD=1 ;;
            S) SORT_DEPS=1 ;;
            D) DEFINES+=("-D$OPTARG") ;;
            I) INCLUDES+=("-I$OPTARG") ;;
            h) usage; exit 0 ;;
            *) usage >&2; exit 1 ;;
        esac
    done
    shift $((OPTIND - 1))

    has_arguments "$@" || { usage >&2; exit 1; }

    FILE=$1
    file_exists "$FILE" || die "file not found: $FILE"

    PARSE_FILE=$(create_tempfile)
    replace_shebang_with_spaces "$FILE" "$PARSE_FILE"

    emit_output
}

main "$@"
