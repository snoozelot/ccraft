#!/bin/sh
# ccompile - compile C files, chronic-style output
#
# Usage: ccompile [-d DIR] [-o FILE] [-v] FILE.c...
#
# Options:
#   -d DIR   Output directory (default: same as source)
#   -o FILE  Output filename (single file only)
#   -v       Show full compiler command
#
# Per-file flags via comment in source:
#   // ccompile [-p PKG]... [CCFLAGS]...
#
# Examples:
#   // ccompile -lm
#   // ccompile -p openssl -p json-c
#   // ccompile -DDEBUG -O0
#
# Dependencies: gcc (or $CC), pkg-config (if -p used)

set -eu

CC=${CC:-gcc}
CFLAGS=${CFLAGS:--O2 -Wall -Wextra}

has_arguments() { [ $# -gt 0 ]; }
is_single()     { [ $# -eq 1 ]; }
is_verbose()    { [ -n "${VERBOSE:-}" ]; }

die()   { echo "ccompile: $*" >&2; exit 1; }
usage() { die "Usage: ccompile [-d DIR] [-o FILE] [-v] FILE.c..."; }

output_path() {
    SRC=$1 OUTDIR=$2 OUTFILE=$3
    if [ -n "$OUTFILE" ]; then echo "$OUTFILE"
    elif [ -n "$OUTDIR" ]; then echo "$OUTDIR/$(basename "${SRC%.c}")"
    else echo "${SRC%.c}"; fi
}

parse_flags() {
    LINE=$(grep -m1 '^// ccompile ' "$1" 2>/dev/null) || { echo ""; return 0; }
    set -- ${LINE#// ccompile }
    FLAGS=
    while [ $# -gt 0 ]; do
        case $1 in
            -p) FLAGS="$FLAGS $(pkg-config --cflags --libs "$2" 2>/dev/null)" || die "pkg-config: $2"; shift 2 ;;
            *) FLAGS="$FLAGS $1"; shift ;;
        esac
    done
    echo "$FLAGS"
}

compile() {
    SRC=$1 OUT=$2
    TOUT="$CCOMPILE_TMP/out"
    TERR="$CCOMPILE_TMP/err"
    FLAGS=$(parse_flags "$SRC")
    RC=0

    if is_verbose; then echo "$CC $CFLAGS $FLAGS -o $OUT $SRC ${LDFLAGS:-}" >&2; fi

    $CC $CFLAGS $FLAGS -o "$OUT" "$SRC" ${LDFLAGS:-} >"$TOUT" 2>"$TERR" || RC=$?

    if [ $RC -ne 0 ]; then
        echo "=== FAILED: $SRC ===" >&2
        cat "$TOUT"
        cat "$TERR" >&2
    fi

    return $RC
}

compile_all() {
    OUTDIR=$1 OUTFILE=$2; shift 2
    TOTAL=$# N=0 FAIL=0

    for SRC in "$@"; do
        N=$((N + 1))
        OUT=$(output_path "$SRC" "$OUTDIR" "$OUTFILE")
        echo "[$N/$TOTAL] $CC $SRC -o $OUT"
        compile "$SRC" "$OUT" || FAIL=1
    done
    return $FAIL
}

main() {
    OUTDIR= OUTFILE= VERBOSE=

    while [ $# -gt 0 ]; do
        case $1 in
            -d) OUTDIR=$2; shift 2 ;;
            -o) OUTFILE=$2; shift 2 ;;
            -v) VERBOSE=1; shift ;;
            -h|--help) usage ;;
            -*) die "unknown option: $1" ;;
            *) break ;;
        esac
    done

    has_arguments "$@" || usage
    [ -z "$OUTFILE" ] || is_single "$@" || die "-o invalid with multiple files"

    # Create a temporary directory for output/error logs
    CCOMPILE_TMP=$(mktemp -d)
    trap 'rm -rf "$CCOMPILE_TMP"' EXIT INT TERM HUP

    compile_all "$OUTDIR" "$OUTFILE" "$@"
}

main "$@"
